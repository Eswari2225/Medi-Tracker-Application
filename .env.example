# Flask Configuration
SECRET_KEY=your-secret-key-here-change-this-in-production

# Database Configuration
DATABASE_URL=sqlite:///meditracker.db
# For PostgreSQL on Render: postgresql://user:password@host:port/database

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
ALERT_EMAIL_FROM=no-reply@meditracker.local

# Flask Environment
FLASK_ENV=production
FLASK_DEBUG=False
